{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Synaptic",
  "version": "0.3.2",
  "identifier": "com.synaptic.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Synaptic",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "decorations": true,
        "transparent": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFQURGMTNCRkE2NDg3MUQKUldRZGgyVDZPL0d0Ym9xZTdZNnNqK2R6VUNRSjFQem44dkxmTkZKcGVYUm9BNjRrbEJKekdNTEMK",
      "endpoints": [
        "https://github.com/addisonking/synaptic/releases/latest/download/latest.json"
      ]
    }
  }
}
